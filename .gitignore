# ============================================================================
# Node.js / npm
# ----------------------------------------------------------------------------
# npm workspaces は基本 root の node_modules/ にホイストされるが、
# 一部 workspace-local な node_modules/ も生成されるためどこでも無視。
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================================
# TypeScript
# ----------------------------------------------------------------------------
# composite build の増分情報 (apps/server, packages/reearth-api-server)
# ============================================================================
*.tsbuildinfo

# ============================================================================
# Build output
# ----------------------------------------------------------------------------
# 各 workspace の dist/ (packages/reearth-api-server/dist, apps/server/dist,
# apps/web/dist) をまとめて無視
# ============================================================================
dist/

# ============================================================================
# Vite / Vitest キャッシュ・カバレッジ
# ============================================================================
.vite/
coverage/
*.lcov

# ============================================================================
# 環境変数 (.env.example のみ commit 対象)
# ----------------------------------------------------------------------------
# apps/server/.env にトークン等を入れる運用。漏洩注意。
# ============================================================================
.env
.env.local
.env.*.local
!.env.example

# ============================================================================
# OS メタデータ
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# Editor / IDE
# ----------------------------------------------------------------------------
# チームで共有したい設定があれば個別に track するか、このルールを緩める。
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Logs
# ============================================================================
*.log

# ============================================================================
# Claude Code ローカル設定
# ----------------------------------------------------------------------------
# .claude/settings.json   : 共有可 (commit OK)
# .claude/settings.local.json : 個人設定 (ignore)
# ============================================================================
.claude/settings.local.json
