# =============================================================================
# Re:Earth CMS 接続設定テンプレート
# このファイルをコピーして `.env` を作成し、実際の値を埋めてください:
#   cp .env.example .env
# `.env` は gitignore 済みなのでコミットされません。
#
# Note: Re:Earth CMS の SDK は workspace / project / model の各識別子を
#       「ID (UUID) or alias/key」のどちらの形式でも受け付けます。
# =============================================================================

# -----------------------------------------------------------------------------
# [必須] CMS API ベース URL (Public / Integration 共通)
# Public API は /api/p/... 、Integration API は /api/{workspace}/... として
# このベース URL 配下にパスが生えます。末尾スラッシュは付けない。
# -----------------------------------------------------------------------------
CMS_BASE_URL=https://api.cms.reearth.io

# -----------------------------------------------------------------------------
# [必須] Workspace 識別子 (ID または alias)
# UI URL の /workspace/... から取得できる UUID、または Workspace 設定で
# 設定した alias 文字列を使用。
# -----------------------------------------------------------------------------
CMS_WORKSPACE=replace-with-workspace-id-or-alias

# -----------------------------------------------------------------------------
# [必須] Project 識別子 (ID または alias)
# UI URL の /project/... から取得できる UUID、またはプロジェクト設定で
# 設定した alias 文字列を使用。
# -----------------------------------------------------------------------------
CMS_PROJECT=replace-with-project-id-or-alias

# -----------------------------------------------------------------------------
# [必須] Integration API token (書き込み系で使用)
# Workspace > Settings > Integration > Connect Integration で発行
# Bearer トークン (例: secret_xxxx...)
# 漏洩注意: .env を gitignore していることを必ず確認
# -----------------------------------------------------------------------------
CMS_INTEGRATION_TOKEN=replace-with-integration-token

# -----------------------------------------------------------------------------
# [任意] Model 識別子 (`npm run -w @hw/reearth-api-server smoke` 専用)
# CLI / MCP / HTTP は subcommand 引数やパラメータで毎回指定するため不要。
# smoke スクリプトだけが env から読みます。
#   - 単一     : CMS_MODEL=move_lob
#   - 複数配列 : CMS_MODEL=[move_lob,hazzrd_reports]
# カンマ区切り、空白は許容されトリムされる。
# -----------------------------------------------------------------------------
# CMS_MODEL=replace-with-model-key-or-[model1,model2]

# -----------------------------------------------------------------------------
# [任意] HTTP サーバ (`reearth-cms serve`) の待受ポート。既定 3000。
# -----------------------------------------------------------------------------
# PORT=3000

# -----------------------------------------------------------------------------
# [任意] `POST /api/assets/file` の multipart アップロード上限 (MB)。既定 32。
# 本番運用では回線・メモリに応じて小さく、大きなデータ取り込みでは拡大する。
# 不正値 (0 以下、数値でない) は警告の上で既定値に戻す。
# -----------------------------------------------------------------------------
# MAX_UPLOAD_MB=32

# -----------------------------------------------------------------------------
# [任意] `POST /api/items/:model` 等 JSON body の上限 (KB)。既定 1024 (= 1 MB)。
# `geometryObject` を含む item は 100 KB を超えやすいので、Express のデフォルト
# (100 KB) に任せると silent に 413 される。ここで明示的に上げておく。
# -----------------------------------------------------------------------------
# MAX_JSON_BODY_KB=1024
